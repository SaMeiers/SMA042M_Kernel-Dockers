# custom.config — kernel config fragment for SM-A042M
# =============================================================================
# This file is merged on top of a04e_defconfig by build_kernel.sh.
# It enables the two Kconfig symbols that Droidspaces/Docker needs but that
# the stock Samsung kernel leaves OFF.
#
# Everything else Docker/Droidspaces needs is ALREADY =y in a04e_defconfig:
#   - NAMESPACES, PID_NS, NET_NS, UTS_NS
#   - CGROUPS, MEMCG
#   - Full NETFILTER (NF_NAT, BRIDGE, VETH, IPTABLES)
#   - OVERLAY_FS
#
# If you add more options here, run `make olddefconfig` to resolve new
# symbols. build_kernel.sh already does this automatically.
# =============================================================================

# User namespaces — required by unprivileged container runtimes
# (Docker rootless, Podman, Droidspaces user isolation)
CONFIG_USER_NS=y

# Device cgroup controller — needed for container device isolation
# (without this, containers cannot reliably access /dev/* nodes)
CONFIG_CGROUP_DEVICE=y
